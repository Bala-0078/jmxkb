ef=\"https://www.connexus.com/connexus_favicon.ico\" />\r\n    <link href=\"https://fonts.googleapis.com/css?family=Open+Sans:400,600,300\" rel=\"stylesheet\" type=\"text/css\">\r\n    <script type=\"text/javascript\" src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/js/jquery.validate.min.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/js/jquery.validate.unobtrusive.js\"></script>\r\n    <script src=\"/js/moment.min.js\"></script>\r\n\r\n    <script src=\"/js/utils.js\"></script>\r\n<script src=\"/js/connexusForms.js\"></script>\r\n<script src=\"/js/cxoverlay.js\"></script>\r\n<script src=\"/js/cxHandlers.js\"></script>\r\n<script src=\"/_control/page/js/iconBar.js\"></script>\r\n<script src=\"/js/header.js\"></script>\r\n<script src=\"/js/feedbackOverlay.js\"></script>\r\n<script src=\"/js/systemMessageClient.js\"></script>\r\n<script src=\"/js/newRelicBrowserMonitoring.js\"></script>\r\n\r\n\r\n    <link href=\"/_stylesheets/debugHide.css\" rel=\"stylesheet\"/>\r\n\r\n    <link href=\"/content/_stylesheets/login.min.css\" rel=\"stylesheet\"/>\r\n\r\n    <link href=\"/_stylesheets/cxForms.css\" rel=\"stylesheet\"/>\r\n\r\n    <link href=\"/_stylesheets/cxOverlay.css\" rel=\"stylesheet\"/>\r\n\r\n    <link href=\"/_stylesheets/feedback.css\" rel=\"stylesheet\"/>\r\n\r\n    <link href=\"/_control/page/iconBar/_stylesheets/iconBar.css\" rel=\"stylesheet\"/>\r\n\r\n</head>\r\n<body>\r\n    <div id=\"adLoadingOverlay\" class=\"cxLoading cxLoadingOverlay blockUI cxLoadingVisible\" style=\"display: none;\">\r\n        <div class=\"cxLoadingMessage\" style=\"margin-top: 20%;\">\r\n            <span class=\"cxIcon cxLoadingIconSmall\" role=\"presentation\"></span>\r\n            <span class=\"loadingText\" role=\"alert\">Loading, please wait...</span>\r\n        </div>\r\n    </div>\r\n    <div class=\"pageWrapper\">\r\n        <a name=\"topOfPage\"></a>\r\n        <div class=\"mainContent\">\r\n            <div id=\"loginContent\" class=\"loginPage environmentIndicator cxForm\">\r\n                <!--Environment Indicator-->\r\n                    <div id=\"environmentIndicator\" class=\"test\">\r\n                        You are in <span id=\"environmentText\">test</span>.\r\n                    </div>\r\n                <!-- Feedback -->\r\n                <div class=\"feedbackWrapper\">\r\n                    <a href=\"/feedback.aspx\" class=\"feedback\" target=\"_blank\">Provide Feedback</a>\r\n                </div>\r\n                <div class=\"loginWrapper\">\r\n                    \r\n\r\n\r\n\r\n    <script src=\"https://d2fnipwtuk1iu0.cloudfront.net/lex-web-ui-loader.min.js\"></script>\r\n    <script src=\"/js/loginChatBotBalloon.js\"></script>\r\n    <script>\r\n        var loginBalloon = new LoginChatBalloon();\r\n\r\n        var loaderOpts = {\r\n            baseUrl: 'https://d2fnipwtuk1iu0.cloudfront.net/',\r\n            shouldLoadMinDeps: true\r\n        };\r\n\r\n        var loader = new ChatBotUiLoader.IframeLoader(loaderOpts);\r\n        var chatbotUiConfig = {\r\n            lex: {\r\n                sessionAttributes: {\r\n                    userAgent: navigator.userAgent,\r\n                    QNAClientFilter: ''\r\n                }\r\n            }\r\n        };\r\n\r\n        loader.load(chatbotUiConfig)\r\n            .then(loginBalloon.displayBalloon)\r\n            .catch(function (error) { console.error(error); });\r\n    </script>\r\n\r\n<div class=\"loginContent\">\r\n    <div class=\"loginMain\" role=\"main\">\r\n\r\n        <!-- Header Image -->\r\n\r\n        <!--Welcome Title & Message-->\r\n        <div class=loginMessaging>\r\n            <h1 class=\"welcomeTitle\">\r\n                Welcome to Pearson Online Classroom\r\n            </h1>\r\n            <p class=\"welcomeMessage\">\r\n                \r\n            </p>\r\n        </div>\r\n\r\n        <!-- Login Logo-->\r\n            <div id=\"loginLogoDiv\" class=\"loginLogo\" runat=\"server\">\r\n                <img src=/_skin/supportFiles/1/572000-762022-104237-PM-209780856.png id=\"loginLogoImage\" alt=Connexus Logo />\r\n            </div>\r\n\r\n        <!-- Sign In Form -->\r\n<form action=\"/login/IesLogin/DetermineLandingPage\" method=\"post\">            <div>\r\n                <input id=\"sendTo\" name=\"sendTo\" type=\"hidden\" value=\"/default.aspx\" />\r\n                <input id=\"partner\" name=\"partner\" type=\"hidden\" value=\"\" />\r\n            </div>\r\n            <fieldset class=\"loginForm cxForm\" id=\"adLoginForm\">\r\n                <legend class=\"visually-hidden\">Log in with your username</legend>\r\n                <div class=\"username-label-container\">\r\n                    <label aria-label=\"Enter username, for example: user.name@pearsonschool.online\" class=\"username-label\" for=\"usernameInput\" id=\"usernameLoginLabel\">Username</label><span class=\"required-asterisk\" aria-label=\"Required\">*</span>\r\n                </div>\r\n                <div class=\"fieldWrapper\">\r\n                    <input aria-labelledby=\"usernameLoginLabel\" autofocus=\"autofocus\" class=\"field firstField\" data-val=\"true\" data-val-required=\"&lt;img class=&#39;errorIcon&#39; role=&#39;presentation&#39; src=&#39;images/icons/error.svg&#39;/>Please enter a username.\" id=\"usernameInput\" name=\"landingPageData.Username\" placeholder=\"e.g., user.name@pearsonschool.online\" required=\"true\" tabindex=\"1\" type=\"text\" value=\"\" />\r\n                </div>\r\n                <span class=\"field-validation-valid invalidMessage\" data-valmsg-for=\"landingPageData.Username\" data-valmsg-replace=\"true\" id=\"errorMessage\" role=\"alert\"></span>\r\n                <span class=\"invalidMessage\" id=\"errorMessage\" role=\"alert\"></span>\r\n                <div class=\"forgot-username-container\">\r\n                    <p id=\"forgotUsernameLink\"><a href=\"/forgot\" tabindex=\"3\">Forgot Username?</a></p>\r\n                    <button id=\"signInButton\" role=\"button\" tabindex=\"2\" class=\"cxButton cxLoginBtn submit login-button-margin-fix\">Next</button>\r\n                </div>\r\n                <div id=\"forgotUsernameBalloon\" style=\"display: none;\">\r\n                    <div aria-hidden=\"true\" id=\"chatBubbleTriangle\" class=\"arrow-up\"></div>\r\n                    <div class=\"forgot-username-bubble forgot-bubble-drop-shadow\" role=\"complementary\" tabindex=\"0\" aria-label=\"Forgot username help balloon.\">\r\n                        <div id=\"forgotUsernameBubbleCloseButton\" role=\"button\" tabindex=\"0\" aria-label=\"Close forgot username info balloon\">\r\n                            <svg width=\"20px\" height=\"20px\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                                <path fill=\"#392f3d\"\r\n                                      fill-rule=\"evenodd\"\r\n                                      clip-rule=\"evenodd\"\r\n                                      d=\"M5.29289 5.29289C5.68342 4.90237 6.31658 4.90237 6.70711 5.29289L12 10.5858L17.2929 5.29289C17.6834 4.90237 18.3166 4.90237 18.7071 5.29289C19.0976 5.68342 19.0976 6.31658 18.7071 6.70711L13.4142 12L18.7071 17.2929C19.0976 17.6834 19.0976 18.3166 18.7071 18.7071C18.3166 19.0976 17.6834 19.0976 17.2929 18.7071L12 13.4142L6.70711 18.7071C6.31658 19.0976 5.68342 19.0976 5.29289 18.7071C4.90237 18.3166 4.90237 17.6834 5.29289 17.2929L10.5858 12L5.29289 6.70711C4.90237 6.31658 4.90237 5.68342 5.29289 5.29289Z\" />\r\n                            </svg>\r\n                        </div>\r\n                        <div class=\"info-bubble-header-text\" tabindex=\"0\" role=\"complementary\">Retrieve Your Username</div>\r\n                        <div tabindex=\"0\" role=\"complementary\"> Follow the link to easily retrieve your username for Pearson Online Classroom.</div>\r\n                    </div>\r\n                </div>\r\n            </fieldset>\r\n</form>    </div>\r\n\r\n    <!-- Login Support -->\r\n    <div class=\"loginSupport\" role=\"complementary\">\r\n        <!-- Support -->\r\n        <div class=\"support\">\r\n            <h2 class=\"audibleOnly\">Contact Support Representative</h2>\r\n            <p>\r\n                Are you having any trouble with the system?<br />\r\n                Call or email a Support Representative. We can help!\r\n            </p>\r\n            <ul class=\"supportInfo\">\r\n                <li>\r\n                    <span class=\"iconWithText\">\r\n                        <span class=\"cxIcon phoneIcon\">Phone: </span>\r\n                        <span id=\"tollFreePhoneNumberLiteral4\" style=\"white-space:nowrap;\">1-800-382-6010</span>\r\n                    </span>\r\n                </li>\r\n                <li>\r\n                    <span class=\"iconWithText\">\r\n                        <span class=\"cxIcon emailIcon\">Email: </span><a id=\"supportEmail\" href=mailto:support@connexus.com>support@connexus.com</a>\r\n                    </span>\r\n                </li>\r\n            </ul>\r\n        </div>\r\n\r\n        <!-- Representative Interactive Support -->\r\n            <div id=\"representative\" class=\"representative\">\r\n                <h2 class=\"audibleOnly\">\r\n                    Interactive Live Support\r\n                </h2>\r\n\r\n                <p id=\"interactiveSupportInterface\" class=\"representativeNote\">\r\n                    Use only if directed by a Support Representative.\r\n                    <a href=\"https://livehelp.connectionseducation.com\" class=\"getSupport\">\r\n                        Get Interactive Support\r\n                    </a>\r\n                </p>\r\n            </div>\r\n\r\n        <!-- Maintenance Mode-->\r\n    </div>\r\n</div>\r\n<div id=\"chatBubbleNote\" style=\"display: none;\">\r\n    <div class=\"chat-button-bubble chat-bubble-drop-shadow\" role=\"complementary\" tabindex=\"0\" aria-label=\"Chat info balloon.\">\r\n        <div id=\"chatBubbleCloseButton\" role=\"button\" tabindex=\"0\" aria-label=\"Close chat info balloon\">\r\n            <svg width=\"20px\" height=\"20px\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                <path fill=\"#392f3d\"\r\n                      fill-rule=\"evenodd\"\r\n                      clip-rule=\"evenodd\"\r\n                      d=\"M5.29289 5.29289C5.68342 4.90237 6.31658 4.90237 6.70711 5.29289L12 10.5858L17.2929 5.29289C17.6834 4.90237 18.3166 4.90237 18.7071 5.29289C19.0976 5.68342 19.0976 6.31658 18.7071 6.70711L13.4142 12L18.7071 17.2929C19.0976 17.6834 19.0976 18.3166 18.7071 18.7071C18.3166 19.0976 17.6834 19.0976 17.2929 18.7071L12 13.4142L6.70711 18.7071C6.31658 19.0976 5.68342 19.0976 5.29289 18.7071C4.90237 18.3166 4.90237 17.6834 5.29289 17.2929L10.5858 12L5.29289 6.70711C4.90237 6.31658 4.90237 5.68342 5.29289 5.29289Z\" />\r\n            </svg>\r\n        </div>\r\n        <div class=\"info-bubble-header-text\" tabindex=\"0\" role=\"complementary\">Trouble logging in?</div>\r\n        <div tabindex=\"0\" role=\"complementary\"> We can help with your new login - just click to chat.</div>\r\n    </div>\r\n    <div>\r\n        <div aria-hidden=\"true\" id=\"chatBubbleTriangle\" class=\"arrow-down\"></div>\r\n    </div>\r\n</div>\r\n                </div>\r\n                <!-- Footer -->\r\n                <div class=\"loginFooterWrapper\">\r\n                    <div class=\"loginFooter\" role=\"contentInfo\">\r\n                        <!-- Footer Static Header -->\r\n                        <div class=\"copyright\">\r\n                            <span id=\"copyrightInfo\">&#169; 2026 Connections Education LLC.</span>\r\n                        </div>\r\n                        <ul class=\"footerLinks\">\r\n                            <!-- Footer Feedback -->\r\n                            <li class=\"footerFeedback\">\r\n                                <a href=\"feedback.aspx\" class=\"feedback\" target=\"_blank\">Provide Feedback</a>\r\n                            </li>\r\n                            <!-- Dynamic Footer Links -->\r\n                                <li><a href=https://www.connectionseducation.com/privacy-policy>Privacy Policy</a></li>\r\n                                <li><a href=https://www.connectionseducation.com/ferpa-notice?>FERPA Notice</a></li>\r\n                                <li><a href=https://www.connectionseducation.com/ppraNotice/>PPRA Notice</a></li>\r\n                                <li><a href=https://www.connectionsacademy.com/accessibility/>Accessibility</a></li>\r\n                            <!-- Static footer links -->\r\n                            <li>\r\n                                <a href=\"https://www.connectionseducation.com/system-requirements/\">System Requirements</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"https://www.connectionseducation.com/terms-of-use/\">Terms of Use</a>\r\n                            </li>\r\n                        </ul>\r\n                    </div>\r\n                </div>\r\n                <!-- Branding -->\r\n                <div class=\"bgBranding\" id=\"bgBranding\" role=\"presentation\">\r\n                    <div style=\"background-image: url(/_skin/supportFiles/1/1170370-10172024-110124-PM-886921510.png)\"></div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <script language=\"javascript\">\r\n        $(function () {\r\n            var isLoggingEnabled = ('test' === 'development');\r\n\r\n            cx.utils.docReady(isLoggingEnabled);\r\n        });\r\n    </script>\r\n\r\n    <script type=\"text/javascript\">\r\n            var externalE2EUrl = \"//e2e-comms-stg.pearson.com/e2ecomms/js-e2e/js-e2e.js\";\r\n    </script>\r\n    <script src=\"/js/pearsonStatusMessage