Location_lastClickedLocation');\r\n\t\t\t\t\tif (idLocation != idLocationOld) {\r\n\t\t\t\t\t\tvar header = document.getElementById('idLocation_locationTreePortal_portalletTitle').childNodes[0];\r\n\t\t\t\t\t\theader.innerHTML = locationName;\r\n\t\t\t\t\t\theader.title = locationName;\r\n\t\t\t\t\t\tportalletExpandCollapse('idLocation_locationTreePortal', 'blue');\r\n\t\t\t\t\t\tsender._selectedValue = idLocation;\r\n\t\t\t\t\t\tlastClickedLocation.value = idLocation;\r\n\t\t\t\t\t}\r\n\t\t\t\t} \r\n\t\t\t</script> <script type=\"text/javascript\">\r\n\t\t\t\t\tvar idLocation_locationTreePortalNeedPopulating = true;\r\n\t\t\t\t</script>\r\n<script type=\"text/javascript\">\r\n//<![CDATA[\r\n$(document).ready(function(){\r\n            Telerik.Web.UI.RadTreeView.prototype.saveClientState = function () {\r\n                return '{\\'expandedNodes\\':' + this._expandedNodesJson +\r\n                    ',\\'collapsedNodes\\':' + this._collapsedNodesJson +\r\n                    ',\\'logEntries\\':' + this._logEntriesJson +\r\n                    ',\\'selectedNodes\\':' + this._selectedNodesJson +\r\n                    ',\\'checkedNodes\\':' + this._checkedNodesJson +\r\n                    ',\\'scrollPosition\\':' + Math.round(this._scrollPosition) + '}';\r\n            }});//]]>\r\n</script>\r\n<script type=\"text/javascript\">\r\n\t\t\t\t\tvar formula_formulaTesterNeedPopulating = true;\r\n\t\t\t\t</script>\r\n<script type=\"text/javascript\">\r\n//<![CDATA[\r\n\r\n\t\t\t\t\tvar caButtons = new Array();\r\n\r\n\t\t\t\t\tfunction caButton_Disable() {\r\n\t\t\t\t\t\tfor (var i = 0; i < caButtons.length; i++)\r\n\t\t\t\t\t\t\ttry {\r\n\t\t\t\t\t\t\t\tcaButtons[i].className = \"disabledButton\";\r\n\t\t\t\t\t\t\t\tcaButtons[i].disabled = true;\r\n\t\t\t\t\t\t\t} catch (e) {\r\n\t\t\t\t\t\t\t}\r\n\t\t\t\t\t}//]]>\r\n</script>\r\n\r\n<script src=\"/Telerik.Web.UI.WebResource.axd?_TSM_HiddenField_=scriptManager_TSM&amp;compress=1&amp;_TSM_CombinedScripts_=%3b%3bSystem.W