v class=\"rtMid\">\r\n\t\t\t\t\t<span class=\"rtSp\"></span><img src=\"/media/locationTypeIcons/other.gif\" alt=\"\" class=\"rtImg\" /><span class=\"rtIn\">SPRINGS Board</span>\r\n\t\t\t\t</div></li><li class=\"rtLI\"><div class=\"rtMid\">\r\n\t\t\t\t\t<span class=\"rtSp\"></span><img src=\"/media/locationTypeIcons/other.gif\" alt=\"\" class=\"rtImg\" /><span class=\"rtIn\">TEC CA Commonwealth Virtual School Board</span>\r\n\t\t\t\t</div></li><li class=\"rtLI\"><div class=\"rtMid\">\r\n\t\t\t\t\t<span class=\"rtSp\"></span><img src=\"/media/locationTypeIcons/other.gif\" alt=\"\" class=\"rtImg\" /><span class=\"rtIn\">TMCF Board</span>\r\n\t\t\t\t</div></li><li class=\"rtLI\"><div class=\"rtMid\">\r\n\t\t\t\t\t<span class=\"rtSp\"></span><img src=\"/media/locationTypeIcons/other.gif\" alt=\"\" class=\"rtImg\" /><span class=\"rtIn\">UCA Board</span>\r\n\t\t\t\t</div></li><li class=\"rtLI\"><div class=\"rtMid\">\r\n\t\t\t\t\t<span class=\"rtSp\"></span><img src=\"/media/locationTypeIcons/other.gif\" alt=\"\" class=\"rtImg\" /><span class=\"rtIn\">WCA Board</span>\r\n\t\t\t\t</div></li><li class=\"rtLI rtLast\"><div class=\"rtBot\">\r\n\t\t\t\t\t<span class=\"rtSp\"></span><img src=\"/media/locationTypeIcons/other.gif\" alt=\"\" class=\"rtImg\" /><span class=\"rtIn\">WillCA Board</span>\r\n\t\t\t\t</div></li>\r\n\t\t\t</ul></li><li class=\"rtLI rtLast\"><div class=\"rtBot\">\r\n\t\t\t\t<span class=\"rtSp\"></span><img src=\"/media/locationTypeIcons/other.gif\" alt=\"\" class=\"rtImg\" /><span class=\"rtIn\">Test Academy</span>\r\n\t\t\t</div></li>\r\n\t\t</ul></li>\r\n\t</ul><input id=\"idLocation_locationTreePortal_locationTree_ClientState\" name=\"idLocation_locationTreePortal_locationTree_ClientState\" type=\"hidden\" />\r\n</div><span id=\"idLocation_locationTreePortal_locationTree_isRequired\" class=\"errorText\" style=\"visibility:hidden;\"></span><div style=\"clear:both;overflow:hidden;\"></div></div><div id=\"idLocation_locationTreePortal_portalletFooter\" class=\"portalletFooter\"><div id=\"idLocation_locationTreePortal_portalletFooterLeft\" class=\"portalletFooterLeft bluePortalletFooterLeft\"></div><div id=\"idLocation_locationTreePortal_portalletFooterRight\" class=\"portalletFooterRight bluePortalletFooterRight\"></div><div id=\"idLocation_locationTreePortal_portalletFooterBorder\" class=\"portalletFooterBorder bluePortalletFooterBorder\"></div></div></div></span></div><span id=\"idLocation_reqVal\" class=\"errorText\" style=\"display:none;\"></span><span id=\"idLocationTypeValidator\" class=\"errorText\" style=\"visibility:hidden;\"><br />This location cannot have extended fields.</span>\r\n\r\n\t\t\t<span id=\"locationNameLabel\"></span>\r\n\t\t</td>\r\n\t</tr>\t\r\n\r\n\t<tr>\r\n\t\t<td class=\"formLabel\">Data&nbsp;Governance: </td>\r\n\t\t<td>\r\n\t\t\t<table>\r\n\t\t\t\t<tr style=\"vertical-align:middle\">\r\n\t\t\t\t\t<td><input id=\"isDataGoverned\" type=\"checkbox\" name=\"isDataGoverned\" /></td>\r\n\t\t\t\t\t<td><a id=\"isDataGovernedHistoryLink\" title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=isDataGoverned&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=isDataGoverned\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"isDataGovernedHistoryLink_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a></td>\r\n\t\t\t\t\t<td><span class=\"formHelp\">This field should appear in the corporate data dictionary, and changes to its options and usages must go through data governance.</span></td>\r\n\t\t\t\t</tr>\r\n\t\t\t</table>\r\n\t\t</td>\r\n\t</tr>\r\n\t<tr>\r\n\t\t<td class=\"formLabelMultiline\">Term ID: </td>\r\n\t\t<td>\r\n\t\t\t<table style=\"vertical-align:middle\">\r\n\t\t\t\t<tr>\r\n\t\t\t\t\t<td>\r\n\t\t\t\t\t\t<input name=\"dataGovernanceTermId\" type=\"text\" maxlength=\"10\" id=\"dataGovernanceTermId\" class=\" field\" size=\"15\" style=\"width:120px\" />\r\n\t\t\t\t\t\t<span id=\"dataGovTermLinkId\" title=\"Link to the Data Governance glossary.\">\r\n            <a href=\"javascript:void(0)\" title=\"Link to the Data Governance glossary.\" onclick=\"showvpninstruction('vpninstruction',true)\">\r\n             <img class=\"ef-datagovernance-link\" src=\"/images/dataGovGlossaryIcon.png\" alt=\"Glossary\"></img>\r\n            </a>\r\n            <div class=\"cxlWrapper\" style=\"display:none\" id=\"vpninstruction\">\r\n                <div class=\"cxlContent cxlVisible\" tabindex=\"0\" aria-labelledby=\"cxlHeader\" style=\"top:45%;max-width:25em;\">\r\n                    <a href=\"javascript:void(0)\" onclick=\"showvpninstruction('vpninstruction',false)\" class=\"cxIcon closeIcon cxlClose\" title=\"Close Window\">Close Window</a>\r\n                    <div class=\"cxlBody\">To access the data governance platform,<br>you must be connected to the following VPN:<br><b>vpn1.pearson.com</b></div>\r\n                    <div class=\"primaryBtns cxlFooter\">\r\n                        <a href=\"https://axon-dataorchestration.pearson.com/glossary\" target=\"_blank\" onclick=\"showvpninstruction('vpninstruction',false)\" class=\"cxBtn cxPrimaryBtn cxlClose\"><text class=\"btnContent\">Continue</text></a>\r\n                        <a href=\"javascript:void(0)\" onclick=\"showvpninstruction('vpninstruction',false)\" class=\"cxBtn cxlClose\"><text class=\"btnContent\">Cancel</text></a>   \r\n                    </div>\r\n                </div>\r\n                <div class=\"cxlBg\" tabindex=\"0\"></div>\r\n            </div>\r\n</span>\r\n\t\t\t\t\t</td>\r\n\t\t\t\t</tr>\r\n                <tr>\r\n\t\t\t\t    <td colspan=\"2\">\r\n\t\t\t\t\t    <span id=\"dataGovernanceTermIdRegExValidator\" class=\"errorText\" evaluationfunction=\"regularExpressionEvaluateIsValid\" style=\"color:;display:none;\">Term Id must be a number greater than 0 with no leading zeros.</span>\r\n\t\t\t\t\t    <span id=\"termIdRequiresDataGovernance1\" class=\"errorText\" updateControlStyle=\"false\" style=\"display:none;\">To specify a Term Id requires the Data Governance checkbox to be checked.</span>\r\n\t\t\t\t\t</td>\r\n\t\t\t\t</tr>\r\n\t\t\t</table>\r\n\t\t</td>\r\n\t</tr>\t\r\n\r\n\t<tr>\r\n\t\t<td class=\"formLabelMultiline\">Categories: </td>\r\n\t\t<td>\r\n\t\t\t<span id=\"idCategory\">There are no <a href=\"categories.aspx\" title=\"Manage categories\">categories</a> at this location.</span>\r\n\t\t</td>\r\n\t</tr>\r\n\t\r\n\t<tr>\r\n\t\t<td class=\"formLabel\">Collect For:</td>\r\n\t\t<td>\r\n\t\t\t<span id=\"idExtendedFieldTypeBorder\" class=\" requiredField\"><select name=\"idExtendedFieldType\" id=\"idExtendedFieldType\" onChange=\"toggleUserCanEdit(this);\" displayRequired=\"True\">\r\n\t<option selected=\"selected\" value=\"\"></option>\r\n\t<option value=\"location\">Location</option>\r\n\t<option value=\"webuser\">User</option>\r\n\r\n</select></span>\r\n\t\t\t<span id=\"ctl02\" class=\"errorText\" style=\"display:none;\"></span>\r\n\t\t\t<span id=\"calculatedFieldTypeValidator\" evaluationfunction=\"validateCompareValidatorEvaluateIsValid\" style=\"display:none;\">Calculated fields can only be created for users and locations.</span>\r\n\t\t\t<span id=\"ConditionalValidator_For_CompareValidator_On_idExtendedFieldType\" class=\"errorText\" style=\"display:none;\">Calculated fields can only be created for users and locations.</span>\r\n\r\n\t\t\t<span id=\"userCanEditLabel\"><span style=\"font-weight:bold;\"><input id=\"ownerCanEdit\" type=\"checkbox\" name=\"ownerCanEdit\" /><label for=\"ownerCanEdit\">Editable By User?</label></span></span>\r\n\t\t</td>\r\n\t</tr>\t\r\n\r\n\t<tr>\r\n\t\t<td class=\"formLabel\">Field Type: </td>\r\n\t\t<td>\r\n\t\t\t<span id=\"idExtendedFieldDataTypeBorder\" class=\" requiredField\"><select name=\"idExtendedFieldDataType\" id=\"idExtendedFieldDataType\" onChange=\"toggleOptionalProperties();\" displayRequired=\"True\">\r\n\t<option selected=\"selected\" value=\"\"></option>\r\n\t<option value=\"boolean\">Yes/No</option>\r\n\t<option value=\"checkbox\">Choose Many</option>\r\n\t<option value=\"date\">Date</option>\r\n\t<option value=\"file\">File</option>\r\n\t<option value=\"lookup\">Calculated</option>\r\n\t<option value=\"select\">Choose One (Drop-Down)</option>\r\n\t<option value=\"selectRadio\">Choose One (Radio Buttons)</option>\r\n\t<option value=\"text\">Single-Line Text Box</option>\r\n\t<option value=\"textarea\">Multi-Line Text Box</option>\r\n\r\n</select></span>\r\n\t\t\t<span id=\"ctl04\" class=\"errorText\" style=\"display:none;\"></span>\r\n\r\n\t\t\t<span id=\"allowFreeEntryLabel\"><span style=\"font-weight:bold;\"><input id=\"allowFreeEntry\" type=\"checkbox\" name=\"allowFreeEntry\" /><label for=\"allowFreeEntry\">Allow Free Entry?</label></span></span>\r\n\t\t</td>\r\n\t</tr>\r\n\r\n\t<tr id=\"allowsFunctionsThatManipulateRolesRow\">\r\n\t\t<td class=\"formLabel\"></td>\r\n\t\t<td>\r\n\t\t\t<span id=\"allowsFunctionsThatManipulateRolesLabel\" class=\"formLabel\"><input id=\"allowsFunctionsThatManipulateRoles\" type=\"checkbox\" name=\"allowsFunctionsThatManipulateRoles\" /><label for=\"allowsFunctionsThatManipulateRoles\">Manipulates Roles?</label></span>\r\n\t\t\t<span id=\"allowsFunctionsThatManipulateRolesHelp\" class=\"formHelp\">Allow this field's formula to call functions that manipulate roles?</span>\r\n\t\t</td>\r\n\t</tr>\r\n\r\n\t<tr id=\"extendedFieldDataFormatRow\">\r\n\t\t<td class=\"formLabel\">Data&nbsp;Format: </td>\r\n\t\t<td>\r\n\t\t\t<span id=\"idExtendedFieldDataFormatBorder\" class=\" requiredField\"><select name=\"idExtendedFieldDataFormat\" id=\"idExtendedFieldDataFormat\" displayRequired=\"True\">\r\n\t<option selected=\"selected\" value=\"\"></option>\r\n\t<option value=\"decimal\">Decimal</option>\r\n\t<option value=\"int\">Integer</option>\r\n\t<option value=\"text\">Text</option>\r\n\r\n</select></span>\r\n\t\t\t<span id=\"extendedFieldDataFormatValidator\" class=\"errorText\" style=\"visibility:hidden;\"><span id=\"ctl21\" class=\"errorText\" style=\"visibility:hidden;\"></span></span>\r\n\t\t</td>\r\n\t</tr>\r\n\r\n\t<tr id=\"calculationOptionsRow\">\r\n\t\t<td class=\"formLabelMultiline\">Frequency: </td>\r\n\t\t<td>\r\n\t\t\t<span id=\"idExtendedFieldCalculationFrequencyBorder\" class=\" field\"><select name=\"idExtendedFieldCalculationFrequency\" id=\"idExtendedFieldCalculationFrequency\">\r\n\t<option value=\"oncePer1Hour\">Not more than once every hour</option>\r\n\t<option value=\"oncePer6Hours\">Not more than once every 6 hours</option>\r\n\t<option value=\"oncePer12Hours\">Not more than once every 12 hours</option>\r\n\t<option selected=\"selected\" value=\"oncePerDay\">Once per day</option>\r\n\t<option value=\"oncePerDayPriority\">Once per day with higher priority</option>\r\n\t<option value=\"oncePerWeekend\">Once Per Week (Weekend Only)</option>\r\n\t<option value=\"never\">Never</option>\r\n\r\n</select></span>\r\n\t\t\t<a id=\"idExtendedFieldCalculationFrequencyHistoryLink\" title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=idExtendedFieldCalculationFrequency&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=idExtendedFieldCalculationFrequency\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"idExtendedFieldCalculationFrequencyHistoryLink_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a>\r\n\t\t\t<span id=\"calculationGroupsMessage\" class=\"formHelp\"></span>\r\n\t\t\t<input name=\"oldExtendedFieldCalculationFrequency\" type=\"hidden\" id=\"oldExtendedFieldCalculationFrequency\" />\r\n\t\t\t<br />\r\n\t\t\t<input id=\"calculateOnlyForMissingValues\" type=\"checkbox\" name=\"calculateOnlyForMissingValues\" /><label for=\"calculateOnlyForMissingValues\">Calculate only for missing values</label>\r\n            <a id=\"calculateOnlyForMissingValuesHistoryLink\" title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=calculateOnlyForMissingValues&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=calculateOnlyForMissingValues\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"calculateOnlyForMissingValuesHistoryLink_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a>\r\n            <br />\r\n            <input id=\"usePrimary\" type=\"checkbox\" name=\"usePrimary\" /><label for=\"usePrimary\">Force primary database only</label>\r\n            <a id=\"usePrimaryHistoryLink\" title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=usePrimary&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=usePrimary\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"usePrimaryHistoryLink_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a>\r\n            <span id=\"usePrimaryWarning\" class=\"warningText\">This option has significant performance implications and should be used sparingly.</span>\r\n            <br />\r\n            <span title=\"Use this option when a field reassigns a variable.\"><input id=\"disableCache\" type=\"checkbox\" name=\"disableCache\" /><label for=\"disableCache\">Disable cache</label></span>            \r\n            <a id=\"disableCacheHistoryLink\" title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=disableCache&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=disableCache\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"disableCacheHistoryLink_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a>\r\n            <span id=\"disableCacheWarning\" class=\"warningText\">This option has significant performance implications and should be used sparingly.</span>\r\n\t\t</td>\r\n\t</tr>\r\n\r\n\t<tr id=\"calculationHistoryRow\">\r\n\t\t<td class=\"formLabelMultiline\">History: </td>\r\n\t\t<td>\r\n\t\t\t<span class=\" field\"><input id=\"noHistory\" type=\"radio\" name=\"HistoryRadioGroup\" value=\"noHistory\" /></span><label for=\"noHistory\" > Do not maintain field history</label> \r\n\t\t\t<br />\r\n\t\t\t<span class=\" field\"><input id=\"temporaryHistory\" type=\"radio\" name=\"HistoryRadioGroup\" value=\"temporaryHistory\" /></span><label for=\"temporaryHistory\" > Maintain field history for 1 year <b>(Default)</b></label>\r\n\t\t\t<span id=\"temporaryHistoryWarning\" class=\"warningText\">This option will have a significant storage impact for large or frequently updated fields.</span>\r\n\t\t\t<br />\r\n\t\t\t<span class=\" field\"><input id=\"permanentHistory\" type=\"radio\" name=\"HistoryRadioGroup\" value=\"permanentHistory\" /></span><label for=\"permanentHistory\" > Maintain field history permanently</label>\r\n\t\t\t<span id=\"permanentHistoryWarning\" class=\"warningText\">This option will have a significant storage impact and should be used sparingly.</span>\r\n\t\t\t<br />\r\n\t\t\t<span id=\"writeHistoryHistoryLinkLabel\" class=\"formHelp\">efcWriteHistory Field History</span>\r\n\t\t\t<a id=\"writeHistoryHistoryLink\" title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=efcWriteHistory&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=efcWriteHistory\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"writeHistoryHistoryLink_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a>\r\n\t\t\t<br />\r\n\t\t\t<span id=\"permanentHistoryHistoryLinkLabel\" class=\"formHelp\">efcPermanentHistory Field History</span>\r\n\t\t\t<a id=\"permanentHistoryHistoryLink\" title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=efcPermanentHistory&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=efcPermanentHistory\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"permanentHistoryHistoryLink_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a>\r\n\t\t</td>\r\n\t</tr>\r\n\r\n\t<tr id=\"formulaRow\">\r\n\t\t<td class=\"formLabelMultiline\">Formula: </td>\r\n\t\t<td>\r\n\t\t\t<span id=\"formula\" cols=\"60\" style=\"display:inline-block;\"><textarea name=\"formula$formula\" rows=\"15\" cols=\"20\" id=\"formula_formula\" class=\" requiredField\" onKeyUp=\"if (document.forms[0].idExtendedField.value.length > 0) document.getElementById(&#39;savedValues&#39;).style.display = (this.value == document.forms[0].oldFormula.value) ? &#39;none&#39; : &#39;inline&#39;; textArea(this, &#39;formula_formula_label&#39;, 0);\" displayRequired=\"True\" onKeyDown=\"catchTabs();\" onBlur=\"textArea(this, &#39;formula_formula_label&#39;, 0);\" onFocus=\"textArea(this, &#39;formula_formula_label&#39;, 0);\" style=\"width:90%;\">\r\n</textarea><span id=\"formula_formula_label\">0</span><a title=\"View field history\" class=\"historyLink\" onClick=\"window.open(&#39;/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=Formula&#39;, &#39;History&#39;, &#39;width=500,height=400,resizable=yes,scrollbars=yes&#39;); return false;\" href=\"/extendedField/fieldHistory.aspx?tableName=extendedField&amp;rowId=&amp;fieldName=Formula\" target=\"_blank\" style=\"display:inline-block;border-width:0px;display:none;vertical-align:middle;\"><img src=\"/images/history.gif\" border=\"0\" alt=\"History Icon\" id=\"formula_ctl00_img\"  style=\"vertical-align: middle; \" title=\"View field history\"  /></a><br /><a href=\"javascript:void(0)\" onClick=\"popupWindow('/extendedField/formulaHelp.aspx?subject=' + getSubject() + '&context=extendedField', 'FormulaHelp', 950, 500, false); return false\" class=\"formHelp\" title=\"Formula Reference\">Help with formulas</a><span class=\"formHelp\">Press the tab key to use indentation in your formula.</span><span id=\"formula_formulaValidator\" class=\"errorText\" style=\"visibility:hidden;\"></span><span id=\"formula_formulaWarnings\" class=\"errorText\"></span><br /><br /><div id=\"formula_formulaTester_portalletMain\" class=\"portalletMain\" aria-label=\"\" role=\"region\" tabindex=\"0\"><div id=\"formula_formulaTester_portalletHeader\" class=\"portalletHeader\"><div id=\"formula_formulaTester_portalletHeaderLeft\" class=\"portalletHeaderLeft bluePortalletHeaderLeft\" onclick=\"portalletExpandCollapse(&#39;formula_formulaTester&#39;, &#39;blue&#39;);\"><input name=\"formula$formulaTester$collapsedState\" type=\"hidden\" id=\"formula_formulaTester_collapsedState\" /></div><div id=\"formula_formulaTester_portalletHeaderRight\" class=\"portalletHeaderRight bluePortalletHeaderRight\"></div><div id=\"formula_formulaTester_portalletHeaderBorder\" class=\"portalletHeaderBorder bluePortalletHeaderBorder\"><div id=\"formula_formulaTester_portalletTitle\" class=\"portalletTitle\" role=\"heading\" aria-level=\"2\">Formula Tester</div>&nbsp;</div></div><div id=\"formula_formulaTester_portalletBody\" style=\"background:transparent;\" class=\"portalletBody bluePortalletBody\"><table>\r\n\t<tr>\r\n\t\t<td colspan=\"3\">Enter a user or location ID and click \"Test Formula\" to run the formula for that user or location. No data will be saved, but you can see the results.</td>\r\n\t</tr><tr>\r\n\t\t<td class=\"formLabel\" style=\"white-space:nowrap;\">User Or Location ID: </td><td><input name=\"formula$formulaTester$rowId\" type=\"text\" id=\"formula_formulaTester_rowId\" class=\" field\" size=\"6\" /><span id=\"formula_formulaTester_ctl08\" class=\"errorText\" evaluationfunction=\"validateNumber\" style=\"color:;visibility:hidden;\"></span></td>\r\n\t</tr><tr>\r\n\t\t<td class=\"formLabelMultiline\" style=\"white-space:nowrap;\">Referenced Fields: </td><td><table id=\"formula_formulaTester_ctl09\" class=\" field\">\r\n\t\t\t<tr>\r\n\t\t\t\t<td><input id=\"formula_formulaTester_ctl09_0\" type=\"radio\" name=\"formula$formulaTester$ctl09\" value=\"true\" /><label for=\"formula_formulaTester_ctl09_0\">Recalculate the values of any calculated fields used by this formula (will not be stored).</label></td>\r\n\t\t\t</tr><tr>\r\n\t\t\t\t<td><input id=\"formula_formulaTester_ctl09_1\" type=\"radio\" name=\"formula$formulaTester$ctl09\" value=\"false\" checked=\"checked\" /><label for=\"formula_formulaTester_ctl09_1\">Use the current values of any calculated fields used by this formula.</label></td>\r\n\t\t\t</tr>\r\n\t\t</table></td>\r\n\t</tr><tr>\r\n\t\t<td colspan=\"2\"><a id=\"caButton_testFormula\" class=\"caButtonHolder\"  onclick=\"\r\n                                    if(navigator.userAgent == &#39;&#39;)\r\n                                          return true;\r\n                                    if (typeof(Page_ClientValidate) == &#39;function&#39;) {\r\n                                          Page_ClientValidate(&#39;&#39;);\r\n                                          if (Page_IsValid) {\r\n                                                caButton_Disable(); __doPostBack(&#39;formula$formulaTester$testFormula&#39;,&#39;&#39;); \r\n                                          } else {\r\n                                                return false;\r\n                                          }\r\n                                    } else {\r\n                                          caButton_Disable(); __doPostBack(&#39;formula$formulaTester$testFormula&#39;,&#39;&#39;);\r\n                                    };\"  href=\"javascript:void(0);\"><input type=\"submit\" name=\"formula$formulaTester$testFormula\" value=\"Test Formula\"  id=\"formula_formulaTester_testFormula\" causesValidation=\"true\" /></a></td>\r\n\t</tr>\r\n</table><div style=\"clear:both;overflow:hidden;\"></div></div><div id=\"formula_formulaTester_portalletFooter\" class=\"portalletFooter\"><div id=\"formula_formulaTester_portalletFooterLeft\" class=\"portalletFooterLeft bluePortalletFooterLeft\"></div><div id=\"formula_formulaTester_portalletFooterRight\" class=\"portalletFooterRight bluePortalletFooterRight\"></div><div id=\"formula_formulaTester_portalletFooterBorder\" class=\"portalletFooterBorder bluePortalletFooterBorder\"></div></div></div></span>\r\n\r\n\t\t\t<span id=\"formulaConditionalValidator\" class=\"errorText\" style=\"visibility:hidden;\"></span>\r\n\t\t\t<span id=\"formulaRequiredFieldValidator\" class=\"errorText\" style=\"visibility:hidden;\"></span>\r\n\t\t\t<input name=\"oldFormula\" type=\"hidden\" id=\"oldFormula\" />\r\n\r\n\t\t\t<span id=\"savedValues\" style=\"display: none\">\r\n\t\t\t<br /><br />The formula has changed. What would you like to do with the calculated data?\r\n\t\t\t<table id=\"eraseSavedValues\" class=\" field\">\r\n\t<tr>\r\n\t\t<td><input id=\"eraseSavedValues_0\" type=\"radio\" name=\"eraseSavedValues\" value=\"false\" checked=\"checked\" /><label for=\"eraseSavedValues_0\">Keep all calculated data until it is recalculated with the new formula.</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"eraseSavedValues_1\" type=\"radio\" name=\"eraseSavedValues\" value=\"true\" /><label for=\"eraseSavedValues_1\">Erase all calculated data for this field now. (Expect to wait about a minute.)</label></td>\r\n\t</tr>\r\n</table>\r\n\t\t\t</span>\r\n\t\t</td>\r\n\t</tr>\r\n\r\n\t<tr>\r\n\t\t<td>&nbsp;</td>\r\n\t\t<td>\r\n\t\t\t<table cellspacing=\"2\" cellpadding=\"2\">\r\n\t<tr id=\"widthRow\">\r\n\t\t<td class=\"formLabel\">Width:</td><td><input name=\"size\" type=\"text\" id=\"size\" class=\" field\" size=\"3\" /><span id=\"ctl06\" class=\"errorText\" evaluationfunction=\"validateNumber\" style=\"color:;visibility:hidden;\"></span>\r\n\t\t\t\t\t\t<span id=\"widthHelpText\" class=\"formHelp\"/>\r\n\t\t\t\t\t</td>\r\n\t</tr><tr id=\"heightRow\">\r\n\t\t<td class=\"formLabel\">Height:</td><td><input name=\"height\" type=\"text\" id=\"height\" class=\" field\" size=\"3\" /><span id=\"ctl07\" class=\"errorText\" evaluationfunction=\"validateNumber\" style=\"color:;visibility:hidden;\"></span>\r\n\t\t\t\t\t\t<span id=\"heightHelpText\" class=\"formHelp\">The height of the TextArea box in rows.</span>\r\n\t\t\t\t\t</td>\r\n\t</tr><tr id=\"minLengthRow\">\r\n\t\t<td id=\"Tablecell1\" class=\"formLabel\" NAME=\"Tablecell1\">Min Length:</td><td id=\"Tablecell2\" NAME=\"Tablecell2\"><input name=\"minLength\" type=\"text\" id=\"minLength\" class=\" field\" size=\"3\" /><span id=\"minLengthValidator\" class=\"errorText\" evaluationfunction=\"validateNumber\" style=\"color:;display:none;\"></span>\r\n\t\t\t\t\t\t<span id=\"minLengthHelpText\" class=\"formHelp\">The minimum length of a value that will be accepted.</span>\t\t\t\t\t\t\r\n\t\t\t\t\t</td>\r\n\t</tr><tr id=\"maxLengthRow\">\r\n\t\t<td class=\"formLabel\">Max Length:</td><td><input name=\"maxLength\" type=\"text\" id=\"maxLength\" class=\" field\" size=\"3\" /><span id=\"maxLengthValidator\" class=\"errorText\" evaluationfunction=\"validateNumber\" style=\"color:;display:none;\"></span>\r\n\t\t\t\t\t\t<span id=\"maxLengthHelpText\" class=\"formHelp\"></span>\r\n\t\t\t\t\t\t<span id=\"maxLengthCompareValidator\" evaluationfunction=\"validateCompareValidatorEvaluateIsValid\" style=\"display:none;\">Max length must be greater than min length.</span></td>\r\n\t</tr>\r\n</table>\r\n\t\t</td>\r\n\t</tr>\r\n\t\r\n\t<tr id=\"fieldOptionsRow\">\r\n\t\t<td>&nbsp;</td>\r\n\t\t<td>\r\n\t\t\tUse the textboxes below to enter the response options.  For existing fields, only responses that have \r\n\t\t\tnot been used as answers will allow you to delete them.  You may use the <strong>Add Option</strong> button to add another \r\n\t\t\tblank textbox for response options.  <strong>Rank is optional</strong> and fields will be displayed ordered by rank first,\r\n\t\t\tthen value.  Note:  Whitespace (blank) and duplicate entries will be ignored; \"Other\" is not an allowable field option.\t\t\t\t\t\t\r\n\r\n\t\t\t\r\n\t\t\t<br/>\r\n\t\t\t\r\n\t\t\t<span id=\"optionsInputErrorMessage\" class=\"errorText\"></span>\r\n\r\n\t\t\tAdd the following list of options, delimited by a\r\n\t\t\t<span id=\"newOptionsDelimiterBorder\" class=\" field\"><select name=\"newOptionsDelimiter\" id=\"newOptionsDelimiter\">\r\n\t<option selected=\"selected\" value=\"\\n\">line break</option>\r\n\t<option value=\",\">comma</option>\r\n\t<option value=\"\\t\">tab</option>\r\n\r\n</select></span>:<br />\r\n\t\t\t<textarea name=\"newOptions\" rows=\"10\" cols=\"100\" id=\"newOptions\" class=\" field\">\r\n</textarea><br />\r\n\t\t\t<input id=\"rankNewOptions\" type=\"checkbox\" name=\"rankNewOptions\" /><label for=\"rankNewOptions\">Add ranks to the new options?</label>\r\n\t\t</td>\r\n\t</tr>\r\n\r\n\t<tr id=\"fileTypesRow\">\r\n\t\t<td class=\"formLabel\">Accepted File Types: </td>\r\n\t\t<td>\r\n\t\t\t<table id=\"extension\" class=\" requiredField\" displayRequired=\"True\">\r\n\t<tr>\r\n\t\t<td><input id=\"extension_0\" type=\"checkbox\" name=\"extension$0\" value=\"anno\" /><label for=\"extension_0\">Annotation Text File (*.anno)</label></td><td><input id=\"extension_30\" type=\"checkbox\" name=\"extension$30\" value=\"png\" /><label for=\"extension_30\">Portable Network Graphics image (*.png)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_1\" type=\"checkbox\" name=\"extension$1\" value=\"avi\" /><label for=\"extension_1\">Microsoft Video for Windows movie (*.avi)</label></td><td><input id=\"extension_31\" type=\"checkbox\" name=\"extension$31\" value=\"pps\" /><label for=\"extension_31\">PowerPoint Show (*.pps)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_2\" type=\"checkbox\" name=\"extension$2\" value=\"bdc\" /><label for=\"extension_2\">West Point Bridge Designer File (*.bdc)</label></td><td><input id=\"extension_32\" type=\"checkbox\" name=\"extension$32\" value=\"ppt\" /><label for=\"extension_32\">PowerPoint Presentation (*.ppt)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_3\" type=\"checkbox\" name=\"extension$3\" value=\"blt\" /><label for=\"extension_3\">AIM Buddy List (*.blt)</label></td><td><input id=\"extension_33\" type=\"checkbox\" name=\"extension$33\" value=\"pptm\" /><label for=\"extension_33\">PowerPoint 2007 Macro-Enabled XML Presentation (*.pptm)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_4\" type=\"checkbox\" name=\"extension$4\" value=\"bmp\" /><label for=\"extension_4\">Windows bitmap image (*.bmp)</label></td><td><input id=\"extension_34\" type=\"checkbox\" name=\"extension$34\" value=\"pptx\" /><label for=\"extension_34\">Microsoft PowerPoint 2007 XML Presentation (*.pptx)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_5\" type=\"checkbox\" name=\"extension$5\" value=\"class\" /><label for=\"extension_5\">Java class (*.class)</label></td><td><input id=\"extension_35\" type=\"checkbox\" name=\"extension$35\" value=\"psd\" /><label for=\"extension_35\">Adobe Photoshop Document (*.psd)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_6\" type=\"checkbox\" name=\"extension$6\" value=\"css\" /><label for=\"extension_6\">Cascading Style Sheet (*.css)</label></td><td><input id=\"extension_36\" type=\"checkbox\" name=\"extension$36\" value=\"pub\" /><label for=\"extension_36\">Microsoft Publisher Document (*.pub)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_7\" type=\"checkbox\" name=\"extension$7\" value=\"csv\" /><label for=\"extension_7\">Comma-separated values file (*.csv)</label></td><td><input id=\"extension_37\" type=\"checkbox\" name=\"extension$37\" value=\"ra\" /><label for=\"extension_37\">RealMedia Streaming Media (*.ra)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_8\" type=\"checkbox\" name=\"extension$8\" value=\"dat\" /><label for=\"extension_8\">Blackboard import file (*.dat)</label></td><td><input id=\"extension_38\" type=\"checkbox\" name=\"extension$38\" value=\"rar\" /><label for=\"extension_38\">WinRAR Compressed Archive File (*.rar)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_9\" type=\"checkbox\" name=\"extension$9\" value=\"doc\" /><label for=\"extension_9\">Microsoft Word document (*.doc)</label></td><td><input id=\"extension_39\" type=\"checkbox\" name=\"extension$39\" value=\"rm\" /><label for=\"extension_39\">RealMedia Streaming Media (*.rm)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_10\" type=\"checkbox\" name=\"extension$10\" value=\"docm\" /><label for=\"extension_10\">Microsoft Word 2007 Macro-Enabled XML Document (*.docm)</label></td><td><input id=\"extension_40\" type=\"checkbox\" name=\"extension$40\" value=\"sql\" /><label for=\"extension_40\">Structured Query Language script (*.sql)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_11\" type=\"checkbox\" name=\"extension$11\" value=\"docx\" /><label for=\"extension_11\">Microsoft Word 2007 XML Document (*.docx)</label></td><td><input id=\"extension_41\" type=\"checkbox\" name=\"extension$41\" value=\"sqlplan\" /><label for=\"extension_41\">SQL Query Plan (*.sqlplan)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_12\" type=\"checkbox\" name=\"extension$12\" value=\"dot\" /><label for=\"extension_12\">Microsoft Word document template (*.dot)</label></td><td><input id=\"extension_42\" type=\"checkbox\" name=\"extension$42\" value=\"tif\" /><label for=\"extension_42\">Tagged Image Format File (*.tif)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_13\" type=\"checkbox\" name=\"extension$13\" value=\"eps\" /><label for=\"extension_13\">Encapsulated PostScript (*.eps)</label></td><td><input id=\"extension_43\" type=\"checkbox\" name=\"extension$43\" value=\"txt\" /><label for=\"extension_43\">Text file (*.txt)</label></td>\r\n\t</tr><tr>\r\n\t\t<td><input id=\"extension_14\" type=\"checkbox\" name=\"extension$14\" value=\"fla\" /><label for=\"extension_14\">Macromedia Flash Movie Authoring File (*.fla)</label></td><td><input id=\"extension_44\" type=\"checkbox\" name=\"