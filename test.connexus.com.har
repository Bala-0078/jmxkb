cument.getElementById('userAvatarTrigger');\r\n        const dropdownTrigger = document.getElementById('userDropdownTrigger');\r\n        if (avatar && dropdownTrigger) {\r\n                avatar.style.cursor = 'pointer';\r\n                avatar.addEventListener('click', (e) => {\r\n                        e.stopPropagation();\r\n                        if (typeof dropdownTrigger.toggleDropdown === 'function') {\r\n                            dropdownTrigger.toggleDropdown();\r\n                        } else {\r\n                            console.warn('toggleDropdown() method not found on dropdownTrigger element.');\r\n                        }\r\n                });\r\n        }\r\n    });\r\n</script>\r\n\r\n<!--This is temp only, this function will be moved!-->\r\n\t<div id=\"powerMenuDiv\" class=\"subNav rightAligned\">\r\n\t\t<ul class=\"menuWithDropdown\" role=\"menubar\">\r\n\t\t\t<li class=\"itemWithDropdown\">\r\n\t\t\t\t\r\n\t\t\t\t<a href=\"javascript: void(0);\" role=\"menuitem\" aria-expanded=\"false\">Quick Go</a>\r\n\t\t\t\t<div class=\"dropdown\">\r\n\t\t\t\t\t<div class=\"arrow\"></div>\r\n\t\t\t\t\t<ul role=\"menu\" id=\"quickGoLinks\" aria-hidden=\"true\">\r\n\t\t\t\t\t\t<li><strong>System</strong></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"addressBookLink\" href=\"/addressBook/\">Address Books</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"assetAwareLink\" href=\"/assetAware/assets.aspx\">AssetAware</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"cacheLink\" href=\"/_locked/developerTools/cache.aspx\">Cache</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"dataviewDevLink\" href=\"/extendedField/dataview/\">Data Views</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"extendedFieldDevLink\" href=\"/extendedField/\">Extended Fields</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"issueAwareSearchDevLink\" href=\"/is