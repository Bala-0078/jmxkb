 </pvs-mobile-menu-item>\r\n                            <pvs-mobile-menu-item text=\"Help\" href=\"/help.aspx\" target=\"_blank\"\r\n                                                  icon-src=\"/images/header/mobile_help.svg\">\r\n                            </pvs-mobile-menu-item>\r\n                </pvs-mobile-main-menu>\r\n            </pvs-mobile-side-menu>\r\n        </pvs-mobile-menu>\r\n    </pvs-header>\r\n</section>\r\n<script>\r\n    document.addEventListener('DOMContentLoaded', () => {\r\n        const avatar = document.getElementById('userAvatarTrigger');\r\n        const dropdownTrigger = document.getElementById('userDropdownTrigger');\r\n        if (avatar && dropdownTrigger) {\r\n                avatar.style.cursor = 'pointer';\r\n                avatar.addEventListener('click', (e) => {\r\n                        e.stopPropagation();\r\n                        if (typeof dropdownTrigger.toggleDropdown === 'function') {\r\n                            dropdownTrigger.toggleDropdown();\r\n                        } else {\r\n                            console.warn('toggleDropdown() method not found on dropdownTrigger element.');\r\n                        }\r\n                });\r\n        }\r\n    });\r\n</script>\r\n\r\n<!--This is temp only, this function will be moved!-->\r\n\t<div id=\"powerMenuDiv\" class=\"subNav rightAligned\">\r\n\t\t<ul class=\"menuWithDropdown\" role=\"menubar\">\r\n\t\t\t<li class=\"itemWithDropdown\">\r\n\t\t\t\t\r\n\t\t\t\t<a href=\"javascript: void(0);\" role=\"menuitem\" aria-expanded=\"false\">Quick Go</a>\r\n\t\t\t\t<div class=\"dropdown\">\r\n\t\t\t\t\t<div class=\"arrow\"></div>\r\n\t\t\t\t\t<ul role=\"menu\" id=\"quickGoLinks\" aria-hidden=\"true\">\r\n\t\t\t\t\t\t<li><strong>System</strong></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"addressBookLink\" href=\"/addressBook/\">Address Books</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"assetAwareLink\" href=\"/assetAware/assets.aspx\">AssetAware</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"cacheLink\" href=\"/_locked/developerTools/cache.aspx\">Cache</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"dataviewDevLink\" href=\"/extendedField/dataview/\">Data Views</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"extendedFieldDevLink\" href=\"/extendedField/\">Extended Fields</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"issueAwareSearchDevLink\" href=\"/issueAware/search.aspx\">IssueAware Search</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"orderAwareDevLink\" href=\"/orderAware/\">Order Manager</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"reportsDevLink\" href=\"/reports/\">Reports</a></li>\r\n\t\t\t\t\t\t<li><strong>LMU</strong></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"assessmentsDevLink\" href=\"/assessments/\">Assessments</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"assessmentsResultsDevLink\" href=\"/assessments/results/manager.aspx\">Assessment Results</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"attendanceDevLink\" href=\"/attendance/enterAttendance.aspx\">Attendance</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"curriculaDevLink\" href=\"/lmu/curricula.aspx\">Curricula</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"curriculaCurrentDevLink\" href=\"/lmu/courses.aspx?idCurriculum=4\">Current Curriculum</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"mediaManagerDevLink\" href=\"/content/\">Media Manager</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"objectivesDevLink\" href=\"/lmu/objectives/\">Objectives</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"sectionsDevLink\" href=\"/lmu/sections/sections.aspx\">Sections</a></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\t\t\t<li class=\"itemWithDropdown\">\r\n\t\t\t\t\r\n\t\t\t\t<a role=\"menuitem\" href=\"javascript: void(0);\" aria-expanded=\"false\">Quick Do</a>\r\n\t\t\t\t<div class=\"dropdown\">\r\n\t\t\t\t\t<div class=\"arrow\"></div>\r\n\t\t\t\t\t<ul role=\"menu\" id=\"quickDoLinks\" aria-hidden=\"true\">\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"createDataViewDevLink\" href=\"/extendedField/dataview/dataview.aspx?idLocation=1\">Create Data View</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"createExtendedFieldDevLink\" href=\"/extendedField/extendedField.aspx?idLocation=1\">Create Extended Field</a></li>\r\n\t\t\t\t\t\t<li><a role=\"menuitem\" tabindex=\"-1\" id=\"createIssueDevLink\" href=\"/issueAware/issue.aspx\">Create Issue</a></li>\r\n\t\t\t\t\t\t<li>\r\n\t\t\t\t\t\t\t<a role=\"menuitem\" tabindex=\"-1\" id=\"composeWebMailDevLink\" title=\"Compose new WebMail message\"\r\n\t\t\t\t\t\t\t   onclick=\" window.open('/webmail?hideHeader=true/#/composemessage', '', 'location=no,resizable=yes,scrollbars=yes,toolbar=no,menubar=no,width=900,height=700'); return false; \"\r\n\t\t\t\t\t\t\t   href=\"/webmail?hideHeader=true/#/composemessage\">Create WebMail Message</a>\r\n\t\t\t\t\t\t</li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</div>\r\n\t\t\t</li>\r\n\r\n\t\t\t<li><a role=\"menuitem\" href=\"/_locked/default.aspx\" title=\"Locked\" target=\"_top\">Locked</a></li>\r\n\t\t\t<li><a role=\"menuitem\" href=\"/_locked/debug.aspx\" title=\"Toggle Debug Mode\" target=\"_blank\">Debug</a></li>\r\n\t\t\t<li><a role=\"menuitem\" href=\"/_locked/session.aspx?resetPermissions=true\" title=\"Reset Permissions\" target=\"_blank\">Reset Permissions</a></li>\r\n\t\t\t<li><a role=\"menuitem\" href=\"/logoff.aspx?sendTo=/login.aspx?sendTo=%2fextendedField%2fextendedField.aspx%3fidLocation%3d1\" title=\"Log Out and Return\" id=\"logoutAndReturnLink\">Log Out and Return</a></li>\r\n\t\t</ul>\r\n\t</div>\r\n<div id=\"subNav\" class=\"subNav\">\r\n    <ul class=\"menuWithDropdown\">\r\n        <li><a name=\"extendedfieldmanager\" title=\"Extended Field Manager\" href=\"default.aspx?idLocation=1\">Extended Field Manager</a></li><li><a name=\"extendedfieldcategorymanager\" title=\"Extended Field Category Manager\" href=\"categories.aspx\">Extended Field Category Manager</a></li><li><a name=\"extendeddataimport\" title=\"Extended Data Import\" href=\"importData.aspx\">Extended Data Import</a></li><li><a name=\"extendedfieldcalculationgroupmanager\" title=\"Extended Field Calculation Group Manager\" href=\"calculationGroups.aspx\">Extended Field Calculation Group Manager</a></li>\r\n    </ul>\r\n</div>\r\n<div class=\"pageContentContainer\">\r\n\r\n<div class=\"contentWrapper\" role=\"main\" aria-labelledby=\"pageTitleHeaderText\" tabindex=\"-1\">\r\n\r\n<h1 id=\"pageTitleHeaderText\" class=\"\"><span id=\"pageTitleHeaderTextSpan\">Manage Extended Field</span></h1><div class=\"mainContent\">\r\n\r\n<script type=\"text/javascript\" src=\"/extendedField/js/dataGovernance.js\"></script>\r\n<script type=\"text/javascript\">\r\nfunction toggleUserCanEdit(element) {\r\n\tvar idExtendedFieldType = getSelectedValue(document.forms[0].idExtendedFieldType);\r\n\tvar idExtendedFieldDataType = getSelectedValue(document.forms[0].idExtendedFieldDataType);\r\n\r\n\tif (idExtendedFieldType == \"webuser\" && idExtendedFieldDataType != \"lookup\")\r\n\t\tdocument.getElementById(\"userCanEditLabel\").style.display = \"inline\";\r\n\telse\r\n\t\tdocument.getElementById(\"userCanEditLabel\").style.display = \"none\";\r\n}\r\n\r\nfunction getSubject() {\r\n\t// For calculated field formula help.\r\n\treturn getSelectedValue(document.forms[0].idExtendedFieldType);\r\n}\r\n\r\nfunction getSelectedValue(dropdown) {\r\n\tif (dropdown.options == null)\r\n\t\t// It's disabled, so it's a hidden rather than a drop down.\r\n\t\treturn dropdown.value;\r\n\telse\r\n\t\treturn dropdown.options[dropdown.options.selectedIndex].value;\r\n}\r\n\r\nfunction makeFieldTypeDictionary(array) {\r\n\tvar properties = new Object();\r\n\r\n\tfor (var i = 0; i < array.length; i++)\r\n\t\tproperties[array[i]] = true;\r\n\r\n\treturn properties;\r\n}\r\n\r\nfunction getDisplay(fieldType, property) {\r\n\tif (fieldTypeProperties[fieldType][property])\r\n\t\treturn \"\";\r\n\treturn \"none\";\r\n}\r\n\r\n// For each field data type, specify the rows that SHOULD be displayed. The rest will be hidden.\r\nvar fieldTypeProperties = new Object();\r\nfieldTypeProperties[\"text\"] = makeFieldTypeDictionary([ \"widthRow\", \"minLengthRow\", \"maxLengthRow\", \"extendedFieldDataFormatRow\" ]);\r\nfieldTypeProperties[\"textarea\"] = makeFieldTypeDictionary([ \"widthRow\", \"minLengthRow\", \"maxLengthRow\", \"heightRow\" ]);\r\nfieldTypeProperties[\"boolean\"] = makeFieldTypeDictionary([\"allowFreeEntryLabel\"]);\r\nfieldTypeProperties[\"selectRadio\"] = makeFieldTypeDictionary([\"fieldOptionsRow\", \"allowFreeEntryLabel\", \"extendedFieldDataFormatRow\"]);\r\nfieldTypeProperties[\"select\"] = fieldTypeProperties[\"selectRadio\"];\r\nfieldTypeProperties[\"checkbox\"] = fieldTypeProperties[\"selectRadio\"];\r\nfieldTypeProperties[\"lookup\"] = makeFieldTypeDictionary([\"formulaRow\", \"calculationOptionsRow\", \"calculationHistoryRow\", \"allowsFunctionsThatManipulateRolesRow\"]);\r\nfieldTypeProperties[\"file\"] = makeFieldTypeDictionary([ \"fileTypesRow\", \"allowMultipleEntriesRow\", \"maximumFileSizeRow\", \"renderInBrowserRow\" ]);\r\n\r\nfunction toggleOptionalProperties() {\r\n\tvar option = getSelectedValue(document.forms[0].idExtendedFieldDataType);\r\n\r\n\tif (fieldTypeProperties[option] != null) {\r\n\t\tdocument.getElementById(\"fieldOptionsRow\").style.display = getDisplay(option, \"fieldOptionsRow\");\r\n\t\tdocument.getElementById(\"allowFreeEntryLabel\").style.display = getDisplay(option, \"allowFreeEntryLabel\");\r\n\t\tdocument.getElementById(\"allowsFunctionsThatManipulateRolesRow\").style.display = getDisplay(option, \"allowsFunctionsThatManipulateRolesRow\");\r\n\t\tdocument.getElementById(\"widthRow\").style.display = getDisplay(option, \"widthRow\");\r\n\t\tdocument.getElementById(\"minLengthRow\").style.display = getDisplay(option, \"minLengthRow\");\r\n\t\tdocument.getElementById(\"maxLengthRow\").style.display = getDisplay(option, \"maxLengthRow\");\r\n\t\tdocument.getElementById(\"heightRow\").style.display = getDisplay(option, \"heightRow\");\r\n\t\tdocument.getElementById(\"formulaRow\").style.display = getDisplay(option, \"formulaRow\");\r\n\t\tdocument.getElementById(\"calculationOptionsRow\").style.display = getDisplay(option, \"calculationOptionsRow\");\r\n        document.getElementById(\"calculationHistoryRow\").style.display = getDisplay(option, \"calculationHistoryRow\");\r\n\t\tdocument.getElementById(\"userCanEditLabel\").style.display = getDisplay(option, \"userCanEditLabel\");\r\n\t\tdocument.getElementById(\"extendedFieldDataFormatRow\").style.display = getDisplay(option, \"extendedFieldDataFormatRow\");\r\n\t\tdocument.getElementById(\"fileTypesRow\").style.display = getDisplay(option, \"fileTypesRow\");\r\n\t\tdocument.getElementById(\"allowMultipleEntriesRow\").style.display = getDisplay(option, \"allowMultipleEntriesRow\");\r\n\t\tdocument.getElementById(\"maximumFileSizeRow\").style.display = getDisplay(option, \"maximumFileSizeRow\");\r\n\t\tdocument.getElementById(\"renderInBrowserRow\").style.display = getDisplay(option, \"renderInBrowserRow\");\r\n\t} else {\r\n\t\tdocument.getElementById(\"fieldOptionsRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"allowFreeEntryLabel\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"allowsFunctionsThatManipulateRolesRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"widthRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"minLengthRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"maxLengthRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"heightRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"formulaRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"calculationOptionsRow\").style.display = \"none\";\r\n        document.getElementById(\"calculationHistoryRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"extendedFieldDataFormatRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"fileTypesRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"allowMultipleEntriesRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"maximumFileSizeRow\").style.display = \"none\";\r\n\t\tdocument.getElementById(\"renderInBrowserRow\").style.display = \"none\";\r\n\t}\r\n\r\n\tswitch (option) {\r\n\t\tcase \"text\":\r\n\t\t\ttoggleUserCanEdit(document.getElementById(\"idExtendedFieldType\"));\r\n\t\t\t// Check to see if it exists first\r\n\t\t\tif (document.getElementById(\"allowFreeEntry\"))\r\n\t\t\t\tdocument.getElementById(\"allowFreeEntry\").checked = false;\r\n\t\t\tif (document.getElementById(\"allowsFunctionsThatManipulateRoles\"))\r\n\t\t\t\tdocument.getElementById(\"allowsFunctionsThatManipulateRoles\").checked = false;\r\n\t\t\tsetInnerText(\"widthHelpText\", \"The width of the TextBox in characters.\");\r\n\t\t\tsetInnerText(\"maxLengthHelpText\", \"The maximum length is unlimited.\");\r\n\t\t\tbreak;\r\n\r\n\t\tcase \"textarea\":\r\n\t\t\ttoggleUserCanEdit(document.getElementById(\"idExtendedFieldType\"));\r\n\t\t\t// Check to see if it exists first\r\n\t\t\tif (document.getElementById(\"allowFreeEntry\"))\r\n\t\t\t\tdocument.getElementById(\"allowFreeEntry\").checked = false;\r\n\t\t\tif (document.getElementById(\"allowsFunctionsThatManipulateRoles\"))\r\n\t\t\t\tdocument.getElementById(\"allowsFunctionsThatManipulateRoles\").checked = false;\r\n\t\t\tsetInnerText(\"widthHelpText\", \"The width of the TextArea box in characters.\");\r\n\t\t\tsetInnerText(\"maxLengthHelpText\", \"The maximum length is unlimited.\");\r\n\t\t\tbreak;\r\n\r\n\t\tcase \"boolean\":\r\n\t\tcase \"selectRadio\":\r\n\t\tcase \"select\":\r\n\t\tcase \"checkbox\":\r\n\t\t\tif (document.getElementById(\"allowsFunctionsThatManipulateRoles\"))\r\n\t\t\t\tdocument.getElementById(\"allowsFunctionsThatManipulateRoles\").checked = false;\r\n\r\n\t\t\ttoggleUserCanEdit(document.getElementById(\"idExtendedFieldType\"));\r\n\t\t\tbreak;\r\n\r\n\t\tcase \"lookup\":\r\n\t\t\tif (document.getElementById(\"userCanEdit\"))\r\n\t\t\t\tdocument.getElementById(\"userCanEdit\").checked = false;\r\n\t\t\tif (document.getElementById(\"allowFreeEntry\"))\r\n\t\t\t\tdocument.getElementById(\"allowFreeEntry\").checked = false;\r\n\t\t\tbreak;\r\n\t\tcase \"file\":\r\n\t\t\tdocument.getElementById(\"userCanEdit\").checked = false;\r\n\t\t\t// Check to see if it exists first\r\n\t\t\tif (document.getElementById(\"allowFreeEntry\"))\r\n\t\t\t\tdocument.getElementById(\"allowFreeEntry\").checked = false;\r\n\t\t\tif (document.getElementById(\"allowsFunctionsThatManipulateRoles\"))\r\n\t\t\t\tdocument.getElementById(\"allowsFunctionsThatManipulateRoles\").checked = false;\r\n\t\t\tbreak;\r\n\r\n\t\tdefault:\r\n\t\t\t// Check to see if it exists first\r\n\t\t\tif (document.getElementById(\"allowFreeEntry\"))\r\n\t\t\t\tdocument.getElementById(\"allowFreeEntry\").checked = false;\r\n\t\t\tif (document.getElementById(\"allowsFunctionsThatManipulateRoles\"))\r\n\t\t\t\tdocument.getElementById(\"allowsFunctionsThatManipulateRoles\").checked = false;\r\n\t\t\ttoggleUserCanEdit(document.getElementById(\"idExtendedFieldType\"));\r\n\t}\r\n}\r\n</script>\r\n\r\n<span id=\"message\" class=\"messageText\"></span>\r\n<span id=\"errorMessage\" class=\"errorText\"></span>\r\n<span id=\"warning\" class=\"warningText\"></span>\r\n\r\n<table class=\"stepIndicator\" cellspacing=\"0\" width=\"100%\" style=\"border-collapse:collapse;\">\r\n\t<tr>\r\n\t\t<td class=\"currentStep\"><span>Properties</span></td><td class=\"stepIndicator\"><span>Associations</span></td>\r\n\t</tr>\r\n</table>\r\n\r\n<form name=\"extendedFieldForm\" method=\"post\" action=\"./extendedField.aspx?idLocation=1\" onsubmit=\"javascript:return WebForm_OnSubmit();\" id=\"extendedFieldForm\">\r\n<div class=\"aspNetHidden\">\r\n<input type=\"hidden\" name=\"scriptManager_TSM\" id=\"scriptManager_TSM\" value=\"\" />\r\n<input type=\"hidden\" name=\"ctl22_TSSM\" id=\"ctl22_TSSM\" value=\"\" />\r\n<input type=\"hidden\" name=\"__EVENTTARGET\" id=\"__EVENTTARGET\" value=\"\" />\r\n<input type=\"hidden\" name=\"__EVENTARGUMENT\" id=\"__EVENTARGUMENT\" value=\"\" />\r\n<input type=\"hidden\" name=\"ConditionalValidator_For_CompareValidator_On_idExtendedFieldType_condition0_conditionalValue0\" id=\"ConditionalValidator_For_CompareValidator_On_idExtendedFieldType_condition0_conditionalValue0\" value=\"lookup\" />\r\n<input type=\"hidden\" name=\"extendedFieldDataFormatValidator_condition0_conditionalValue0\" id=\"extendedFieldDataFormatValidator_condition0_conditionalValue0\" value=\"text\" />\r\n<input type=\"hidden\" name=\"extendedFieldDataFormatValidator_condition0_conditionalValue1\" id=\"extendedFieldDataFormatValidator_condition0_conditionalValue1\" value=\"select\" />\r\n<input type=\"hidden\" name=\"extendedFieldDataFormatValidator_condition0_conditionalValue2\" id=\"extendedFieldDataFormatValidator_condition0_conditionalValue2\" value=\"selectRadio\" />\r\n<input type=\"hidden\" name=\"extendedFieldDataFormatValidator_condition0_conditionalValue3\" id=\"extendedFieldDataFormatValidator_condition0_conditionalValue3\" value=\"checkbox\" />\r\n<input type=\"hidden\" name=\"formulaConditionalValidator_condition0_conditionalValue0\" id=\"formulaConditionalValidator_condition0_conditionalValue0\" value=\"lookup\" />\r\n<input type=\"hidden\" name=\"ConditionalValidator_For_RequiredFieldValidator_On_extension_condition0_conditionalValue0\" id=\"ConditionalValidator_For_RequiredFieldValidator_On_extension_condition0_conditionalValue0\" value