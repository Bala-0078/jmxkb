          "content": {
            "size": 4112,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\n\n\n<title>Pearson Connexus Login</title>\n<link rel=\"stylesheet\" href=\"/css/login-iframe.css\" />\n\n</head>\n\n<body class=\"login-body\">\n\t<script>\n\t\twindow.onload = function() {\n\t\t\tvar backgroundImage = new Image();\n\t\t\tbackgroundImage.src = \"/images/background.jpg\";\n\t\t\tvar background = document.querySelector('.bg-large');\n\t\t\tbackgroundImage.onload = function(){\n\t\t\t\tbackground.classList.add('enhanced');\n\t\t\t}\n\n\t\t\tvar planeWrapper = document.querySelector('.plane-wrapper'),\n\t\t\t\tpaperPlane = document.querySelector('.paper-plane'),\n\t\t\t\tpaperPlaneImage = new Image(),\n\t\t\t\tshadowPlane = document.querySelector('.shadow-plane'),\n\t\t\t\tshadowPlaneImage = new Image(),\n\t\t\t\tplanesLoaded = 0;\n\n\t\t\tpaperPlaneImage.src = '/images/paper-plane.png';\n\t\t\tshadowPlaneImage.src = '/images/shadow-plane.png';\n\n\t\t\tpaperPlaneImage.onload = function(){\n\t\t\t\tplanesLoaded++;\n\t\t\t\tif(planesLoaded === 2) {\n\t\t\t\t\tplaneWrapper.classList.add('animated');\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tshadowPlaneImage.onload = function(){\n\t\t\t\tplanesLoaded++;\n\t\t\t\tif(planesLoaded === 2) {\n\t\t\t\t\tplaneWrapper.classList.add('animated');\n\t\t\t\t}\n\t\t\t}\n\n\t\t};\n\t</script>\n\t<div class=\"background\">\n\t\t<div class=\"bg-small\"></div>\n\t\t<div class=\"bg-large\"></div>\n\t</div>\n\t<div class=\"small-screen\">\n\t\tFor the best experience, we recommend a screen resolution higher than <span class=\"size\">1024x768</span>.\n\t</div>\n\t<!-- for IE 11 and below -->\n    <div class=\"older-browser-display\">\n        It looks like you may be using an older browser. For the best experience, we recommend using the latest version of Google Chrome, Mozilla Firefox, Microsoft Edge, or Apple Safari.\n    </div>\n\t<div class=\"wrapper\">\n\t\t<div class=\"img-wrapper\">\n\t\t\t<blockquote class=\"text\">\n\t\t\t\t\t&ldquo;The world is but a canvas to the imagination.&rdquo;\n\t\t\t</blockquote>\n\t\t\t<span class=\"author\">Henry David Thoreau</span>\n\t\t\t<span class=\"plane-wrapper\">\n\t\t\t\t<span class=\"paper-plane\"></span>\n\t\t\t\t<span class=\"shadow-plane\"></span>\n\t\t\t</span>\n\t\t</div>\n\t\t<div class=\"login-wrapper\">\n\t\t</div>\n\t</div>\n\t<footer class=\"footer\">\n\t\t<div class=\"copyright-wrapper\">\n\t\t\t<span class=\"pearson-logo\">Pearson Connexus</span>\n\t\t\t\t\t\t<span class=\"copyright\">&copy; <script type=\"text/javascript\">document.write(new Date().getFullYear());</script> Pearson Education. All rights reserved.</span>\n\t\t</div>\n\t\t<div class=\"footer-link-wrapper\">\n\t\t\t<ul class=\"support\">\n\t\t\t\t<li class=\"support-line\">\n\t\t\t\t\tSupport Line: <a href=\"tel:18445973224\">+1 844 597 3224</a>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<!--Point to Pearson-branded-->\n\t\t\t\t\t<a href=\"https://www.gotoassist.com/ph/pcx\" target=\"_blank\" class=\"interactive-support\">Get Interactive Support\n\t\t\t\t\t\t<span class=\"support-access\">Use only if directed by a Support Representative</span>\n\t\t\t\t\t</a>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t\t<ul class=\"footer-links\">\n                <li>\n                    <a href=\"https://pearsonconnexus.zendesk.com/hc/en-us/articles/360007993234-Connexus-EMS-System-Requirements\"\n                        target=\"_blank\">System Requirements</a>\n                </li>\n                <li>\n\t\t\t\t\t<a href=\"https://pearsonconnexus.zendesk.com/hc/en-us/articles/115004874854-Protection-of-Pupil-Rights-Amendment-PPRA-Notification\" target=\"_blank\">PPRA Notice</a>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<a href=\"https://pearsonconnexus.zendesk.com/hc/en-us/articles/115004874714-FERPA-Annual-Notification-and-Policy\" target=\"_blank\">FERPA Notice</a>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<a href=\"https://pearsonconnexus.zendesk.com/hc/en-us/articles/115004874674-Privacy-Policy\" target=\"_blank\">Privacy Policy</a>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<a href=\"https://pearsonconnexus.zendesk.com/hc/en-us/articles/115004881953-Terms-of-Use\" target=\"_blank\">Terms of Use</a>\n\t\t\t\t</li>\n\t\t\t\t<li>\n\t\t\t\t\t<a href=\"https://pearsonconnexus.zendesk.com/hc/en-us/articles/115004576254-Release-Notes\" target=\"_blank\">Release Notes</a>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t</div>\n\t</footer>\n</body>\n</html>\n"
          },
