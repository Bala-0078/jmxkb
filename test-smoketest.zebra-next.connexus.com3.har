            "size": 815,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html>\n    <body>\n        <script>\n            try {\n                let cnxUrl = \"https://testcurrent.connexus.com\",    //uses testcurrent due to vpn limitations for integration.connexus.com\n                    urlParams = new URLSearchParams(window.location.search),\n                    token = urlParams.get('token'),\n                    req = new XMLHttpRequest();\n\n                req.addEventListener(\"load\", function() { console.log('sccf: Got Connexus content access'); });\n                req.open('GET', `${cnxUrl}/lmu/migration/contentauth/lmscontentcookiehandler.ashx?pcxauthtoken=${token}`);\n                req.withCredentials = true;\n                req.send();\n            } catch (e) {\n                console.error(`sccf: ${e}`);\n            }\n        </script>\n    </body>\n</html>"
          },
